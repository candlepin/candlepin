<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.19.xsd">

    <changeSet id="20230830134215-1" author="crog">

        <!--
            TODO: create a new table, copy products (and content) to the new tables, temporarily
            leave the old table about for manual fixing or rolling back of junk

            For now, just modify cp2_products and cp2_content a bit; but don't actually do this
            outside of the prototype.
        -->


        <dropUniqueConstraint tableName="cp2_products" constraintName="cp2_product_entity_version"/>
        <dropIndex tableName="cp2_products" indexName="cp2_products_idx2"/>

        <dropColumn tableName="cp2_products" columnName="entity_version" />

        <createIndex tableName="cp2_products" indexName="cp2_products_idx2" unique="true">
            <column name="product_id"/>
        </createIndex>


        <dropUniqueConstraint tableName="cp2_content" constraintName="cp2_content_entity_version"/>
        <dropIndex tableName="cp2_content" indexName="cp2_content_idx2"/>

        <dropColumn tableName="cp2_content" columnName="entity_version" />

        <createIndex tableName="cp2_content" indexName="cp2_content_idx2" unique="true">
            <column name="content_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>


